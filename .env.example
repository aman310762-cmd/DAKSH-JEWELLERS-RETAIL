# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Daksh Jewellers — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/daksh-jewellers

# Cloudinary (image hosting)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Admin Authentication
JWT_SECRET=your-very-long-random-secret-key-here-minimum-32-chars
ADMIN_EMAIL=admin@dakshjewellers.com
ADMIN_PASSWORD_HASH=  # Generate with: node scripts/generateHash.js yourpassword

# WhatsApp (public — no secrets)
NEXT_PUBLIC_WHATSAPP_NUMBER=919896424648

# Backend API URL (set after deploying backend)
NEXT_PUBLIC_API_URL=
