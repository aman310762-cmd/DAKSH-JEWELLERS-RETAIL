# ─── MongoDB Atlas ───────────────────────────────────
# Get this from: mongodb.com/atlas → Cluster → Connect → Connection String
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/daksh-jewellers

# ─── Admin Login (for backend auth) ─────────────────
# The email admin uses to login (can be same as Username)
ADMIN_EMAIL=Parveen@123
# Password hash — generate with: node scripts/generateHash.js Focused123
ADMIN_PASSWORD_HASH=$2b$10$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# JWT secret for admin sessions — use any long random string
JWT_SECRET=your-super-secret-random-string-change-this

# ─── Cloudinary (for product images) ────────────────
# Get these from: cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── NO Render needed — everything runs on Vercel! ──
# Leave this empty or remove it for Vercel deployment
# NEXT_PUBLIC_API_URL is not needed anymore
